# Configuration de déploiement OVH Web Cloud
# Copie ce fichier en .env.deploy puis remplis les valeurs.
# Récupère-les dans OVH → Web Cloud → ton hébergement → onglet FTP-SSH.

# Hôte SFTP/SSH (le numéro du cluster varie)
OVH_HOST="ftp.cluster021.hosting.ovh.net"

# Login SFTP/SSH
OVH_USER="tonsite-ovh"

# Répertoire web racine (souvent /www, parfois /htdocs)
OVH_REMOTE_DIR="/www"

# Port SSH/SFTP (22 par défaut chez OVH)
OVH_PORT="22"

# Mot de passe SFTP — uniquement pour les offres OVH sans clé SSH
# (Web Cloud Éco, hébergement Perso…). Laisse vide si tu utilises une clé SSH.
OVH_PASSWORD=""
